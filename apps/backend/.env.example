# Copy this file to .env before starting the backend.
# Keep real secrets only in local .env and do not commit them.

# Neo4j / Aura defaults
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password
NEO4J_DATABASE=
AURA_INSTANCEID=
AURA_INSTANCENAME=

# LLM defaults
# Use mock for local development without a real API key.
LLM_PROVIDER=mock
LLM_MODEL=qwen-plus
LLM_BASE_URL=https://api.siliconflow.cn/v1

# Fill this in locally when enabling a real provider.
LLM_API_KEY=
LLM_FAST_MODEL=Qwen/Qwen3-32B
LLM_REASON_MODEL=deepseek-ai/DeepSeek-V3.2
LLM_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_QWEN_API_KEY=
LLM_QWEN_MODEL=qwen-plus
