### AL ###
#Template for AL projects for Dynamics 365 Business Central
#launch.json folder
.vscode/
#Cache folder
.alcache/
#Symbols folder
.alpackages/
#Snapshots folder
.snapshots/
#Testing Output folder
.output/
#Extension App-file
*.app
#Rapid Application Development File
rad.json
#Translation Base-file
*.g.xlf
#License-file
*.flf
#Test results file
TestResults.xml

# Python
__pycache__/
*.pyc
.venv/
.env
.env.*
!.env.example

# Node / Next.js
node_modules/
.next/
.idea/

# Local data — keep .gitkeep for empty dirs, track everything else
# data/uploads/student_submissions/**/*
!data/uploads/student_submissions/.gitkeep
# data/project_state/**/*
!data/project_state/.gitkeep

# Teacher examples: keep only structure docs in git
data/corpus/teacher_examples/**/*.pdf
data/corpus/teacher_examples/**/*.ppt
data/corpus/teacher_examples/**/*.pptx
data/corpus/teacher_examples/**/*.doc
data/corpus/teacher_examples/**/*.docx
data/corpus/teacher_examples/**/._*
!data/corpus/teacher_examples/README.md
!data/corpus/teacher_examples/**/.gitkeep